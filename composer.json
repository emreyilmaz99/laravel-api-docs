{
    "name": "laravel-api-docs/generator",
    "description": "Laravel projelerinde route, FormRequest ve controller'lardan otomatik interaktif API dokümantasyonu üreten paket",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Developer",
            "email": "dev@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelApiDocs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelApiDocs\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelApiDocs\\ApiDocsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
